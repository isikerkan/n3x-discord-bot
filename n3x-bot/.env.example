# ─── Discord ──────────────────────────────────────────────────────────────
# Rotate the old leaked token first: Developer Portal -> Bot -> Reset Token
DISCORD_TOKEN=your-bot-token-here

# ─── Storage ──────────────────────────────────────────────────────────────
# flatfile | sqlite | postgres
STORAGE_BACKEND=flatfile

# Required when STORAGE_BACKEND is sqlite or postgres.
# sqlite:   sqlite+aiosqlite:///data/n3x.db
# postgres: postgresql+asyncpg://n3x:n3x@postgres:5432/n3x
DATABASE_URL=

# Path for flatfile backend
# Under Docker, this is only persisted if the path is inside data/ (the
# mounted bot-data volume) — docker-compose.yml sets DATA_FILE=data/stats.json
# by default for this reason.
DATA_FILE=stats.json

# ─── Discord IDs / behavior ───────────────────────────────────────────────
TARGET_ROLE_ID=0
WELCOME_CHANNEL_ID=0
REMINDER_CHANNEL_ID=0
# User ID used as the fixed target of the !home targeted stat. 0 disables.
JULEZ_ID=0
# Role allowed to run !admin ... and /admin ... CRUD commands. 0 disables.
ADMIN_ROLE_ID=0
PREFIX_STR=[N3X]
COMMAND_PREFIX=!
REMINDER_TIME=19:30

# ─── Gate tracker ───────────────────────────────────────────────────────────
# Channel members post `a 46892` / `b ...` / `c ...` cost entries into.
GATE_INPUT_CHANNEL_ID=0
# Channel the live gate-stats embed is posted/updated in.
GATE_STATS_CHANNEL_ID=0
# Role allowed to run `!del <a|b|c> <index>`.
GATE_DELETE_ROLE_ID=0
# gate_type:reward pairs, comma-separated.
GATE_REWARDS=a:46892,b:93820,c:139522

# ─── Activity tracking ──────────────────────────────────────────────────────
# IANA timezone used for daily streak / night-owl day boundaries.
TIMEZONE=Europe/Berlin

# ─── Achievements / Milestones ─────────────────────────────────────────────
# Channel milestone announcement cards are posted in. 0 disables.
MILESTONE_CHANNEL_ID=0
# Channel the paginated achievement overview (!overview) is posted in. 0 disables.
OVERVIEW_CHANNEL_ID=0
# Voice achievement_id:role_id mapping, comma-separated, granting voice-tier
# roles on unlock. Example: voice_bronze:123,voice_gold:456. Empty disables.
VOICE_ACHIEVEMENT_ROLES=

# ─── Kodex (rules acceptance) ───────────────────────────────────────────────
# Channel the !kodex_check confirmation audit is posted in. 0 disables.
KODEX_CHECK_CHANNEL_ID=0

# ─── Base timers ────────────────────────────────────────────────────────────
# Role allowed to run !base / !basestop. 0 disables the commands.
BASE_TIMER_ROLE_ID=0
# Channel holding the self-editing base-timer overview. 0 disables it.
TIMER_OVERVIEW_CHANNEL_ID=0
# Message ID of the fixed message the overview edits in place. 0 disables it.
TIMER_OVERVIEW_MESSAGE_ID=0
# Comma-separated whitelist of map names accepted by !base.
ALLOWED_MAPS=4-1,4-2,4-3,4-4,1-5,1-6,1-7,2-5,2-6,2-7,3-5,3-6,3-7
