# ─── Discord ──────────────────────────────────────────────────────────────
# Rotate the old leaked token first: Developer Portal -> Bot -> Reset Token
DISCORD_TOKEN=your-bot-token-here

# ─── Storage ──────────────────────────────────────────────────────────────
# flatfile | sqlite | postgres
STORAGE_BACKEND=flatfile

# Required when STORAGE_BACKEND is sqlite or postgres.
# sqlite:   sqlite+aiosqlite:///data/n3x.db
# postgres: postgresql+asyncpg://n3x:n3x@postgres:5432/n3x
DATABASE_URL=

# Path for flatfile backend
# Under Docker, this is only persisted if the path is inside data/ (the
# mounted bot-data volume) — docker-compose.yml sets DATA_FILE=data/stats.json
# by default for this reason.
DATA_FILE=stats.json

# ─── Discord IDs / behavior ───────────────────────────────────────────────
TARGET_ROLE_ID=0
WELCOME_CHANNEL_ID=0
REMINDER_CHANNEL_ID=0
# Role allowed to run !admin ... and /admin ... CRUD commands. 0 disables.
ADMIN_ROLE_ID=0
PREFIX_STR=[N3X]
COMMAND_PREFIX=!
REMINDER_TIME=19:30

# ─── Gate tracker ───────────────────────────────────────────────────────────
# Channel members post `a 46892` / `b ...` / `c ...` cost entries into.
GATE_INPUT_CHANNEL_ID=0
# Channel the live gate-stats embed is posted/updated in.
GATE_STATS_CHANNEL_ID=0
# Role allowed to run `!del <a|b|c> <index>`.
GATE_DELETE_ROLE_ID=0
# gate_type:reward pairs, comma-separated.
GATE_REWARDS=a:46892,b:93820,c:139522

# ─── Activity tracking ──────────────────────────────────────────────────────
# IANA timezone used for daily streak / night-owl day boundaries.
TIMEZONE=Europe/Berlin

# ─── Achievements / Milestones ─────────────────────────────────────────────
# Channel milestone announcement cards are posted in (later pass). 0 disables.
MILESTONE_CHANNEL_ID=0
# Channel the achievement overview UI is posted in (later pass). 0 disables.
OVERVIEW_CHANNEL_ID=0
# Voice achievement -> role id mapping (later pass). Empty disables.
VOICE_ACHIEVEMENT_ROLES=
